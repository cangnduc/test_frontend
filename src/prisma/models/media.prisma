model Media {
  id      String    @id @default(cuid())
  type    MediaType
  url     String    @db.Text
  ownerId Int
  User    User      @relation("UserCreatedMedia", fields: [ownerId], references: [id])

  questions Question[]
  passages  Passage[]
  testCover Test?      @relation("TestCover")

  isDeleted Boolean @default(false)
  alt       String?
  size      Int?
  mimeType  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
